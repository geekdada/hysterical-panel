# Copy to .env and fill in values:  cp .env.example .env
# Load locally with direnv (recommended):  direnv allow
# PocketBase does not read .env files; variables must be in the process environment.

# Required — AES-GCM master key for node api_secret (any non-empty passphrase works)
PANEL_MASTER_KEY=change-me-to-a-long-random-string

# Optional — panel UI origin for CORS (http:// or https://, no path; unset = allow *)
# PANEL_FRONTEND_URL_BASE=http://localhost:3000

# Optional — public panel API origin for GET /api/panel/config (http:// or https://, no path)
# PANEL_BACKEND_URL_BASE=http://localhost:8090

# Optional — preflight cache TTL in seconds (default 7200; browsers may cap; 0 = no Max-Age)
# PANEL_CORS_MAX_AGE=7200

# Optional — PocketBase data directory (default: ./pb_data)
# PB_DATA_DIR=./pb_data

# Optional — directory containing Country-asn.mmdb and Country-without-asn.mmdb
# MMDB_DIR=./mmdb

# Optional — encrypt PocketBase app settings at rest (see PocketBase docs)
# PB_ENCRYPTION_KEY=
