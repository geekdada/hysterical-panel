{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "react", "import", "jsx-a11y"],
  "env": {
    "browser": true
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  },
  "ignorePatterns": [
    "src/routeTree.gen.ts",
    "src/api/schema.d.ts",
    "node_modules/**",
    ".output/**",
    "dist/**"
  ],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "eslint/no-underscore-dangle": [
      "warn",
      {
        "allow": ["__APP_VERSION__"]
      }
    ]
  }
}
