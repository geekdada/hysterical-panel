{
  "name": "hysterical-panel-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "api:schema": "cd ../backend && PANEL_MASTER_KEY=skip go run . openapi-schema -o openapi.json",
    "api:types": "openapi-typescript ../backend/openapi.json -o src/api/schema.d.ts",
    "api:sync": "pnpm api:schema && pnpm api:types"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-start": "^1.168.18",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
