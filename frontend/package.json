{
  "name": "hysterical-panel-frontend",
  "version": "0.11.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ./.output/server/index.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "prepare": "cd .. && husky",
    "api:schema": "../scripts/generate-openapi-schema.sh",
    "api:types": "openapi-typescript ../backend/openapi.json -o src/api/schema.d.ts",
    "api:sync": "pnpm api:schema && pnpm api:types"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@gravity-ui/icons": "^2.18.0",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@internationalized/date": "^3.12.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-start": "^1.168.18",
    "@tanstack/react-table": "^8.21.3",
    "nitro": "3.0.260522-beta",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint --fix"
    ],
    "*.{js,jsx,ts,tsx,json,jsonc}": "oxfmt --no-error-on-unmatched-pattern"
  }
}
